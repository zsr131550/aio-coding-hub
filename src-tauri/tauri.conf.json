{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AIO Coding Hub",
  "version": "0.60.15",
  "identifier": "io.aio.codinghub",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "AIO Coding Hub",
        "width": 1500,
        "height": 900,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "visible": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' asset: https://asset.localhost data: blob:; font-src 'self' data:; media-src 'self'; connect-src 'self' ipc: http://ipc.localhost http://127.0.0.1:* https://github.com https://api.github.com https://objects.githubusercontent.com; frame-src 'none'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "resources/plugins/official/privacy-filter/**/*"
    ],
    "windows": {
      "wix": {
        "upgradeCode": "c1b4a027-411b-5de5-94b9-b6953c022c17",
        "fragmentPaths": [
          "wix/remove-stale-start-menu-shortcut.wxs"
        ],
        "componentRefs": [
          "RemoveStaleStartMenuShortcut"
        ]
      }
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/FingerCaster/aio-coding-hub/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEQ5ODk4RDdGQTU3MkE0NjcKUldSbnBIS2xmNDJKMlRJSDYrdXFkRnpxR2NFeGFoSDN3dlB3aDRNbVFYK0tmRXBpS2VzRkRZZ2EK",
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
